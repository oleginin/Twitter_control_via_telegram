# Your Twitter/X username WITHOUT the @ symbol (legacy, single account fallback)
TWITTER_USERNAME=your_twitter_username

# Comma-separated list of Twitter/X usernames to monitor (e.g. 0leshkoo,elonmusk)
TWITTER_USERNAMES=your_twitter_username,another_user

# ─── X Cookie Authentication (for Like, Bookmark, Reply) ──
# Open Developer Tools (F12) on x.com -> Application/Storage -> Cookies
# Copy auth_token and ct0 cookie values here:
TWITTER_COOKIE_AUTH_TOKEN=your_auth_token_here
TWITTER_COOKIE_CT0=your_ct0_here

# ─── X Proxy (Highly Recommended for API interactions) ───
# Format: http://username:password@ip:port or http://ip:port
TWITTER_PROXY=

# ─── AI Client Configuration (Gemini or OpenAI compatible) ──
# Option 1: Direct Google Gemini API (default)
# Get a free API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Option 2: OpenAI-Compatible API (OpenRouter, Groq, Ollama, DeepSeek, etc.)
# Set AI_PROVIDER to 'openai_compatible' to enable it.
AI_PROVIDER=gemini
AI_API_KEY=your_provider_api_key_here
AI_API_URL=https://openrouter.ai/api/v1/chat/completions
AI_MODEL=google/gemini-2.5-flash:free


# ─── Telegram ─────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff-example

# ID of the chat or channel to send tweets to
# Personal chat : run  python bot.py --get-chat-id  to find it
# Channel       : -100xxxxxxxxxx  (use @getidsbot)
TELEGRAM_CHAT_ID=324161815

# ─── Optional settings ────────────────────────────────
# How often to check for new tweets, in minutes (default: 5)
CHECK_INTERVAL_MINUTES=30

# Number of batches to split the accounts list into (default: 2)
NUM_BATCHES=5

# Number of tweets to fetch per check and on startup (default: 10)
INITIAL_FETCH_COUNT=1

# Filename for storing seen tweet IDs (default: seen_tweets.json)
STATE_FILE=seen_tweets.json
